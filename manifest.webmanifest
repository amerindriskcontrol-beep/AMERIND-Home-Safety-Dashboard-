<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Home Ready — AMERIND</title>
  <meta name="description" content="Home Ready: A simple, offline-capable learning game for first-time residents. AMERIND — Tribes Protecting Tribes." />
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f0f4f3;
      --fg: #0d1a19;
      --muted: #5a6e6c;
      --primary: #0a6b67;
      --primary-2: #07403d;
      --primary-light: #e2f0ef;
      --accent: #f0a500;
      --accent-light: #fff8e6;
      --good: #1a7a40;
      --good-bg: #e6f7ed;
      --bad: #c0392b;
      --bad-bg: #fce8e6;
      --card: #ffffff;
      --border: #d8e5e4;
      --shadow: 0 2px 12px rgba(10,75,72,.07);
      --shadow-lg: 0 8px 32px rgba(10,75,72,.12);
      --radius: 16px;
      --radius-sm: 10px;
      --font-display: 'Sora', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }
    [data-contrast="high"] {
      --bg: #111; --fg: #fff; --card: #1a1a1a; --primary: #5dd8d2;
      --primary-2: #5dd8d2; --border: #333; --muted: #aaa;
      --primary-light: #0d2e2d; --shadow: 0 2px 12px rgba(0,0,0,.5);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--fg);
      font-size: 16px;
      line-height: 1.55;
    }

    /* ── HEADER ── */
    header {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-2) 100%);
      color: #fff;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 16px rgba(0,0,0,.2);
    }
    header .logo {
      width: 38px; height: 38px;
      background: rgba(255,255,255,.15);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    header h1 {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: .3px;
    }
    header small { display: block; opacity: .75; font-size: .75rem; font-weight: 400; margin-top: 1px; }
    .hc-toggle {
      margin-left: auto;
      display: flex; align-items: center; gap: 8px;
      font-size: .8rem; color: rgba(255,255,255,.85);
    }
    .toggle {
      width: 40px; height: 22px;
      background: rgba(255,255,255,.25);
      border-radius: 999px; position: relative; cursor: pointer;
      border: 1px solid rgba(255,255,255,.3);
      transition: background .2s;
      flex-shrink: 0;
    }
    .toggle::after {
      content: "";
      position: absolute;
      width: 18px; height: 18px;
      background: #fff;
      border-radius: 999px;
      top: 1px; left: 1px;
      transition: left .2s ease;
    }
    .toggle[aria-checked="true"] { background: var(--accent); }
    .toggle[aria-checked="true"]::after { left: 19px; }

    /* ── LAYOUT ── */
    #app { max-width: 900px; margin: 0 auto; padding: 20px 16px 80px; }

    /* ── CARDS ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
    }

    /* ── BUTTONS ── */
    .btn {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: .9rem;
      padding: 11px 20px;
      border-radius: var(--radius-sm);
      border: none;
      cursor: pointer;
      transition: transform .08s, box-shadow .15s, opacity .15s;
      display: inline-flex; align-items: center; gap: 6px;
      letter-spacing: .2px;
    }
    .btn:active { transform: scale(.97); }
    .btn:disabled { opacity: .45; cursor: not-allowed; }
    .btn-primary { background: var(--primary); color: #fff; box-shadow: 0 2px 8px rgba(10,107,103,.3); }
    .btn-primary:hover:not(:disabled) { box-shadow: 0 4px 16px rgba(10,107,103,.35); }
    .btn-secondary { background: var(--primary-light); color: var(--primary-2); }
    .btn-danger { background: var(--bad); color: #fff; }
    .btn-accent { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(240,165,0,.3); }
    .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--primary-light); color: var(--primary); border-color: var(--primary-light); }

    /* ── BADGES ── */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      background: var(--primary-light); color: var(--primary-2);
      padding: 4px 10px; border-radius: 999px;
      font-size: .78rem; font-weight: 600;
      border: 1px solid rgba(10,107,103,.15);
    }

    /* ── PROGRESS BAR ── */
    .progress-bar {
      height: 6px; background: var(--border); border-radius: 999px; overflow: hidden;
    }
    .progress-bar > .fill {
      height: 100%; background: linear-gradient(90deg, var(--primary), var(--accent));
      border-radius: 999px;
      transition: width .4s cubic-bezier(.4,0,.2,1);
    }

    /* ── MODULE GRID ── */
    .module-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-top: 16px; }
    .module-card {
      background: var(--card);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      cursor: pointer;
      transition: border-color .2s, box-shadow .2s, transform .15s;
      position: relative;
      overflow: hidden;
    }
    .module-card:hover { border-color: var(--primary); box-shadow: var(--shadow-lg); transform: translateY(-2px); }
    .module-card.done { border-color: var(--good); }
    .module-card.done::after {
      content: "✓";
      position: absolute; top: 10px; right: 12px;
      background: var(--good); color: #fff;
      width: 22px; height: 22px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: .8rem; font-weight: 700;
    }
    .module-icon { font-size: 2rem; margin-bottom: 10px; line-height: 1; }
    .module-card h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
    .module-card p { font-size: .82rem; color: var(--muted); margin-bottom: 12px; line-height: 1.4; }

    /* ── TABS ── */
    .tab-row {
      display: flex; gap: 4px;
      background: var(--bg);
      padding: 4px;
      border-radius: var(--radius-sm);
      margin-bottom: 20px;
    }
    .tab-btn {
      flex: 1;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: .82rem;
      padding: 9px 8px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      color: var(--muted);
      background: transparent;
      transition: all .2s;
      letter-spacing: .2px;
    }
    .tab-btn[aria-selected="true"] {
      background: var(--card);
      color: var(--primary);
      box-shadow: var(--shadow);
    }
    .tab-btn.done-tab::after { content: " ✓"; }

    /* ── LEARN TAB ── */
    .learn-card {
      background: var(--primary-light);
      border-radius: var(--radius-sm);
      padding: 16px 20px;
      margin-bottom: 10px;
      font-size: .95rem;
      border-left: 4px solid var(--primary);
      animation: slide-in .25s ease;
    }
    .learn-card .step-num {
      font-family: var(--font-display);
      font-size: .72rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }
    @keyframes slide-in {
      from { opacity:0; transform: translateX(-12px); }
      to   { opacity:1; transform: translateX(0); }
    }

    /* ── QUIZ STYLES ── */
    .q-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px;
    }
    .q-counter {
      font-family: var(--font-display);
      font-size: .8rem;
      font-weight: 700;
      color: var(--muted);
      background: var(--bg);
      padding: 4px 12px;
      border-radius: 999px;
    }
    .q-text {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.4;
      margin-bottom: 18px;
      animation: fade-up .25s ease;
    }
    .choices { display: flex; flex-direction: column; gap: 10px; }
    .choice-btn {
      width: 100%;
      text-align: left;
      font-family: var(--font-body);
      font-size: .95rem;
      font-weight: 500;
      padding: 14px 18px;
      border-radius: var(--radius-sm);
      border: 2px solid var(--border);
      background: var(--card);
      cursor: pointer;
      transition: all .15s;
      display: flex; align-items: center; gap: 12px;
      color: var(--fg);
    }
    .choice-btn:hover:not(:disabled) { border-color: var(--primary); background: var(--primary-light); color: var(--primary-2); }
    .choice-btn.correct { border-color: var(--good); background: var(--good-bg); color: var(--good); font-weight: 700; }
    .choice-btn.wrong { border-color: var(--bad); background: var(--bad-bg); color: var(--bad); }
    .choice-btn:disabled { cursor: default; }
    .choice-letter {
      width: 28px; height: 28px; min-width: 28px;
      border-radius: 50%;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: .8rem;
      font-weight: 700;
      color: var(--muted);
      transition: all .15s;
    }
    .choice-btn.correct .choice-letter { background: var(--good); color: #fff; }
    .choice-btn.wrong .choice-letter { background: var(--bad); color: #fff; }
    .choice-btn:hover:not(:disabled) .choice-letter { background: var(--primary); color: #fff; }
    .explain-box {
      margin-top: 14px;
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      background: var(--accent-light);
      border-left: 4px solid var(--accent);
      font-size: .88rem;
      color: var(--fg);
      animation: fade-up .2s ease;
    }
    .next-hint {
      text-align: center;
      font-size: .78rem;
      color: var(--muted);
      margin-top: 10px;
      animation: pulse 1.5s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:.5} 50%{opacity:1} }

    /* ── HOT OR NOT ── */
    .hon-card {
      min-height: 110px;
      padding: 24px;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 700;
      background: var(--primary-light);
      border-radius: var(--radius);
      margin-bottom: 16px;
      animation: fade-up .25s ease;
    }
    .hon-btns { display: flex; gap: 10px; }
    .hon-btns .btn { flex: 1; justify-content: center; font-size: 1rem; padding: 14px; }
    .hon-score { text-align: center; font-size: .82rem; color: var(--muted); margin-top: 10px; }

    /* ── FIND & FIX ── */
    .hazard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; }
    .hazard-item {
      border: 2px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 14px;
      transition: all .2s;
    }
    .hazard-item.fixed { border-color: var(--good); background: var(--good-bg); }
    .hazard-title { font-family: var(--font-display); font-weight: 700; font-size: .9rem; margin-bottom: 8px; }
    .hazard-tip { font-size: .82rem; color: var(--good); margin-top: 8px; display: none; }
    .hazard-item.fixed .hazard-tip { display: block; animation: fade-up .2s ease; }

    /* ── DRAG DROP ── */
    .drag-area { display: flex; flex-direction: column; gap: 8px; }
    .draggable {
      padding: 12px 14px;
      border-radius: var(--radius-sm);
      border: 2px dashed var(--border);
      background: var(--bg);
      cursor: grab;
      font-size: .9rem;
      font-weight: 500;
      user-select: none;
      transition: all .15s;
    }
    .draggable:hover { border-color: var(--primary); background: var(--primary-light); }
    .draggable.placed { opacity: .45; cursor: default; }
    .dropzone {
      border: 2px dashed var(--border);
      border-radius: var(--radius-sm);
      padding: 12px;
      min-height: 60px;
      background: var(--bg);
      transition: all .2s;
    }
    .dropzone.drag-over { border-color: var(--primary); background: var(--primary-light); }
    .dropzone.zone-ok { border-color: var(--good); background: var(--good-bg); border-style: solid; }
    .dropzone.zone-bad { border-color: var(--bad); background: var(--bad-bg); border-style: solid; }
    .zone-label { font-family: var(--font-display); font-size: .82rem; font-weight: 700; color: var(--muted); margin-bottom: 6px; }
    .zone-contents { font-size: .8rem; color: var(--fg); }

    /* ── CALENDAR ── */
    .month-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .month-zone {
      border: 2px dashed var(--border);
      border-radius: var(--radius-sm);
      padding: 8px;
      min-height: 52px;
      transition: all .15s;
      text-align: center;
    }
    .month-zone.drag-over { border-color: var(--primary); background: var(--primary-light); }
    .month-zone.has-task { border-color: var(--accent); border-style: solid; background: var(--accent-light); }
    .month-name { font-family: var(--font-display); font-size: .78rem; font-weight: 700; color: var(--muted); }
    .month-tasks { font-size: .7rem; color: var(--fg); margin-top: 3px; }

    /* ── QUIZ RESULT ── */
    .result-block {
      text-align: center; padding: 28px 20px;
      animation: fade-up .3s ease;
    }
    .result-score {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--primary);
      line-height: 1;
    }
    .result-label { font-size: .9rem; color: var(--muted); margin-top: 4px; }
    .badge-earned {
      margin: 20px auto;
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, var(--accent), #e09000);
      color: #fff;
      padding: 10px 20px;
      border-radius: 999px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: .95rem;
      box-shadow: 0 4px 16px rgba(240,165,0,.35);
      animation: pop .4s cubic-bezier(.34,1.56,.64,1);
    }
    @keyframes pop { from{transform:scale(.5);opacity:0} to{transform:scale(1);opacity:1} }
    @keyframes fade-up { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

    /* ── TOAST ── */
    .toast {
      position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
      background: var(--primary-2); color: #fff;
      padding: 12px 20px; border-radius: 999px;
      font-size: .88rem; font-weight: 500;
      box-shadow: 0 4px 20px rgba(0,0,0,.25);
      z-index: 999; white-space: nowrap;
      transition: opacity .2s;
    }
    .toast.correct-t { background: var(--good); }
    .toast.wrong-t { background: var(--bad); }

    /* ── INSTALL BTN ── */
    #installBtn {
      position: fixed; bottom: 16px; left: 16px;
      z-index: 200;
    }

    /* ── CERTIFICATE / HOME ── */
    .home-header {
      margin-bottom: 20px;
      padding: 28px 24px;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      border-radius: var(--radius);
      color: #fff;
    }
    .home-header-eyebrow {
      font-family: var(--font-display);
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      opacity: .7;
      margin-bottom: 8px;
    }
    .home-header h2 {
      font-family: var(--font-display);
      font-size: 1.55rem;
      font-weight: 800;
      margin-bottom: 8px;
      line-height: 1.2;
    }
    .home-header p { opacity: .82; font-size: .88rem; line-height: 1.5; margin-bottom: 4px; }
    .overall-progress {
      margin-top: 16px;
      display: flex; align-items: center; gap: 12px;
    }
    .overall-progress .progress-bar { flex: 1; height: 8px; background: rgba(255,255,255,.25); }
    .overall-progress .fill { background: var(--accent); }
    .overall-progress span { font-family: var(--font-display); font-weight: 700; font-size: .9rem; white-space: nowrap; }

    .cert-card {
      background: linear-gradient(135deg, var(--accent-light), #fff);
      border: 2px solid var(--accent);
      border-radius: var(--radius);
      padding: 20px;
      text-align: center;
      margin-top: 16px;
    }
    .cert-card h3 { font-family: var(--font-display); font-weight: 700; margin-bottom: 6px; }

    /* ── MODULE HEADER ── */
    .module-hero {
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      color: #fff;
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 16px;
      display: flex; align-items: center; gap: 14px;
    }
    .module-hero-icon { font-size: 2.5rem; line-height: 1; }
    .module-hero h2 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; }
    .module-hero p { opacity: .8; font-size: .85rem; margin-top: 2px; }

    /* ── COMMUNITY TIP ── */
    .community-tip {
      margin-top: 16px;
      padding: 12px 16px;
      background: var(--card);
      border-radius: var(--radius-sm);
      border-left: 4px solid var(--accent);
      font-size: .85rem;
      color: var(--muted);
    }
    .community-tip strong { color: var(--fg); }

    /* ── RESPONSIVE ── */
    @media (max-width: 480px) {
      .module-grid { grid-template-columns: 1fr 1fr; }
      .month-grid { grid-template-columns: repeat(3, 1fr); }
      .hon-btns .btn { padding: 12px 8px; }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">🏠</div>
    <div>
      <h1>Home Ready</h1>
      <small>An AMERIND Risk Control Program</small>
    </div>
    <div class="hc-toggle">
      <label for="contrastToggle" style="cursor:pointer">High contrast</label>
      <div id="contrastToggle" class="toggle" tabindex="0" role="switch" aria-checked="false" aria-label="Toggle high contrast"></div>
    </div>
  </header>

  <main id="app" tabindex="-1" aria-live="polite"></main>
  <button class="btn btn-secondary" id="installBtn" style="display:none">⬇ Install App</button>
  <div id="toast" class="toast" style="display:none" role="status" aria-live="polite"></div>

  <script src="app.js"></script>
</body>
</html>
